{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "installCommand": "npm install",
  "framework": null,
  "redirects": [
    {
      "source": "/",
      "has": [
        {
          "type": "host",
          "value": "discord.ibroski.net"
        }
      ],
      "destination": "https://discord.gg/pWUQB4bNVd",
      "permanent": true
    }
  ],
  "headers": [
    {
      "source": "/.well-known/discord",
      "headers": [
        {
          "key": "Content-Type",
          "value": "text/plain; charset=utf-8"
        }
      ]
    }
  ],
  "rewrites": [
    { 
      "source": "/((?!\\.well-known\/).*)", 
      "destination": "/index.html" 
    }
  ]
}
